# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/reddit_tracker

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Reddit (optional - leave empty to use public .json endpoints) ──
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# ── AI Providers (wire up later) ──────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_PROVIDER=claude   # or: openai
